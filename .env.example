# =============================================
# Catalyst Training Co — Reporting Config
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- Xero ---
XERO_CLIENT_ID=your_client_id
XERO_CLIENT_SECRET=your_client_secret
XERO_REDIRECT_URI=http://localhost:5000/callback
XERO_TENANT_ID=your_tenant_id

# --- Meta Marketing API ---
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_long_lived_token
META_AD_ACCOUNT_ID=act_your_account_id

# --- GymMaster ---
GYMMASTER_API_KEY=your_api_key
GYMMASTER_API_URL=https://your-site.gymmaster.co.nz/api/v1

# --- Email (Gmail SMTP) ---
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=your_email@gmail.com
